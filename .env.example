# ---------------------------------------------------------------------------
# ai-eval environment template.  Copy to `.env` and fill in ONLY what you need.
#
# The offline first checkpoint (Milestones 0-4) needs NONE of these.
# All tests and the `ai-eval demo` run without any credentials, using
# deterministic recorded target adapters.
#
# Provider keys are opt-in and are only consulted by the live provider
# adapters introduced in Milestone 5.  They are never required by CI, the
# demo, or the deterministic regression gate.
# ---------------------------------------------------------------------------

# --- Model providers (Milestone 5, opt-in) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Vector store / RAG (Milestone 7, via docker-compose) ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# --- Persistence (Milestone 6, via docker-compose) ---
# DATABASE_URL=postgresql+psycopg://ai_eval:ai_eval@localhost:5432/ai_eval
# REDIS_URL=redis://localhost:6379/0

# --- Artifact storage ---
# AI_EVAL_RUNS_DIR=runs
