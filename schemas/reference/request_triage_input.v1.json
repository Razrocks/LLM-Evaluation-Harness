{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-eval/schemas/reference/request_triage_input.v1.json",
  "title": "request_triage.input.v1",
  "description": "Input contract for reference.request_triage.v1. A relative deadline cannot be interpreted without received_at and reference_timezone, so both are required.",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "message", "received_at", "reference_timezone", "documents"],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "message": { "type": "string" },
    "received_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp WITH offset, e.g. 2026-07-13T10:00:00-04:00."
    },
    "reference_timezone": {
      "type": "string",
      "description": "IANA timezone name, e.g. America/Toronto.",
      "minLength": 1
    },
    "documents": {
      "type": "array",
      "items": { "$ref": "#/$defs/document" }
    },
    "metadata": { "$ref": "#/$defs/metadata" }
  },
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id", "document_version", "text", "content_hash"],
      "properties": {
        "document_id": { "type": "string", "minLength": 1 },
        "document_version": { "type": ["string", "integer"] },
        "text": { "type": "string" },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:.+",
          "description": "Content hash of the document text, prefixed 'sha256:'."
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "type": ["string", "null"], "enum": ["email", "form", "chat", "other", null] },
        "priority_hint": { "type": ["string", "null"], "enum": ["low", "medium", "high", null] },
        "category_hint": { "type": ["string", "null"] }
      }
    }
  }
}
