{
  "gate_id": "reference_request_triage_v1_ci",
  "gate_version": "1",
  "description": "Default deterministic regression gate for reference.request_triage.v1. Thresholds are calibration defaults, not universal truths.",
  "rules": [
    { "rule_id": "no_critical_case_failures", "type": "critical_case_count_max", "maximum": 0, "severity": "critical" },
    { "rule_id": "schema_floor", "type": "metric_minimum", "metric": "schema_pass_rate", "minimum": 0.95, "severity": "critical" },
    { "rule_id": "deadline_floor", "type": "metric_minimum", "metric": "deadline_accuracy", "minimum": 0.90, "severity": "major" },
    { "rule_id": "risk_macro_f1_floor", "type": "metric_minimum", "metric": "risk_macro_f1", "minimum": 0.85, "severity": "major" },
    { "rule_id": "high_risk_recall_floor", "type": "metric_minimum", "metric": "high_risk_recall", "minimum": 0.95, "severity": "critical" },
    { "rule_id": "missing_information_recall_floor", "type": "metric_minimum", "metric": "missing_information_recall", "minimum": 0.85, "severity": "major" },
    { "rule_id": "needs_attention_floor", "type": "metric_minimum", "metric": "needs_attention_accuracy", "minimum": 0.90, "severity": "major" },
    { "rule_id": "invalid_evidence_ceiling", "type": "metric_maximum", "metric": "invalid_evidence_reference_rate", "maximum": 0.02, "severity": "major" },
    { "rule_id": "missing_information_regression", "type": "baseline_delta_minimum", "metric": "missing_information_recall", "minimum_delta": -0.03, "requires_baseline": true, "severity": "major" }
  ]
}
