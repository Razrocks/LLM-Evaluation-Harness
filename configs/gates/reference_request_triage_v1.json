{
  "gate_id": "reference_request_triage_v1_ci",
  "gate_version": "1.0.0",
  "description": "First-slice deterministic regression gate for reference.request_triage.v1. Thresholds are starting defaults calibrated against the recorded_pass baseline, not universal truths. Two metrics are deliberately NOT gated here: cost_per_case_usd (requires a versioned price table, absent offline) and evidence_reference_validity (no case in dataset v1 declares an evidence_reference_valid assertion, so its denominator is 0). A rule over an absent metric correctly yields INVALID rather than PASS, so the rule is omitted until the metric exists.",
  "rules": [
    {
      "rule_id": "no_critical_case_failures",
      "type": "critical_case_count_max",
      "maximum": 0,
      "severity": "critical"
    },
    {
      "rule_id": "schema_floor",
      "type": "metric_minimum",
      "metric": "schema_pass_rate",
      "minimum": 0.95,
      "severity": "critical"
    },
    {
      "rule_id": "high_risk_recall_floor",
      "type": "metric_minimum",
      "metric": "risk_recall.high",
      "minimum": 0.95,
      "severity": "critical"
    },
    {
      "rule_id": "risk_macro_f1_floor",
      "type": "metric_minimum",
      "metric": "risk_macro_f1",
      "minimum": 0.85,
      "severity": "major"
    },
    {
      "rule_id": "deadline_accuracy_floor",
      "type": "metric_minimum",
      "metric": "deadline_accuracy",
      "minimum": 0.90,
      "severity": "major"
    },
    {
      "rule_id": "missing_information_recall_floor",
      "type": "metric_minimum",
      "metric": "missing_information_recall",
      "minimum": 0.85,
      "severity": "major"
    },
    {
      "rule_id": "needs_attention_accuracy_floor",
      "type": "metric_minimum",
      "metric": "needs_attention_accuracy",
      "minimum": 0.90,
      "severity": "major"
    },
    {
      "rule_id": "unsupported_material_claim_ceiling",
      "type": "metric_maximum",
      "metric": "unsupported_material_claim_rate",
      "maximum": 0.0,
      "severity": "critical"
    },
    {
      "rule_id": "latency_p95_budget",
      "type": "metric_maximum",
      "metric": "latency_p95_ms",
      "maximum": 5000.0,
      "severity": "minor"
    },
    {
      "rule_id": "missing_information_recall_no_regression",
      "type": "baseline_delta_minimum",
      "metric": "missing_information_recall",
      "minimum_delta": -0.03,
      "requires_baseline": true,
      "severity": "major"
    }
  ]
}
